{
  "name": "intesis-apontamento-desktop",
  "version": "0.9.4",
  "description": "Sistema de Apontamento Industrial - Intesis",
  "main": "app/background.js",
  "author": "Felipe De Paula",
  "private": true,
  "scripts": {
    "dev": "nextron",
    "build": "nextron build",
    "postinstall": "electron-builder install-app-deps",
    "dist": "nextron build",
    "publish": "nextron build --publish always"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "electron-log": "^5.4.3",
    "electron-serve": "^1.3.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.460.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.11.16",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3",
    "next": "^16.2.0",
    "nextron": "^9.6.0",
    "postcss": "^8.4.38",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.intesis.apontamento",
    "productName": "Intesis Apontamento",
    "copyright": "Copyright © 2026 Intesis Brasil Tecnologia",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "felipe-de-paula-dev",
        "repo": "intesis-apontamento-desktop",
        "private": true,
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico",
      "publisherName": "Intesis Brasil Tecnologia",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Intesis Apontamento",
      "artifactName": "Intesis-Apontamento-Setup-${version}.${ext}",
      "uninstallDisplayName": "Remover Intesis Apontamento"
    }
  }
}
